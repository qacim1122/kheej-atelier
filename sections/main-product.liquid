{% comment %}
  Main Product — Milestone 1 + 2 (unchanged, see prior inline comments)
  + Milestone 3 (JS enhancement layer).

  Progressive enhancement: everything below still works exactly as
  Milestone 2 left it with JavaScript disabled — the wrapping custom
  element is just an unrecognized custom element until JS defines it, so it
  renders as an inert wrapper with no effect on the existing forms/
  radios/hrefs. product-form.js hooks in via connectedCallback and does
  three things: (1) prevents the intermediate GET-forms' default
  navigation, (2) recomputes the matching variant client-side on every
  radio change using a JSON payload of product.variants, and (3)
  updates price/compare-price/button state/add-to-cart id/featured
  image directly, no reload.

  Important: the existing radio `value` attributes from Milestone 2 are
  pre-computed at page-LOAD time and go stale the instant JS changes a
  different option without reloading — so JS never trusts a radio's
  `value` for matching. Each radio also carries data-option-position
  and data-option-value (the raw option string, e.g. "Red") specifically
  so the JS can recompute matches itself; the `value` attribute is then
  kept in sync by JS purely so the no-JS submission path (name="id")
  stays correct if JS fails partway or is unavailable.

  Variant prices are pre-formatted server-side (via the money filter)
  into the JSON payload, not reconstructed in JS — currency/locale
  formatting is shop-configurable and genuinely complex; reimplementing
  it client-side would be fragile and wrong for non-USD shops.
{% endcomment %}

{{ 'main-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer></script>

{%- liquid
  assign featured_image = product.featured_image
  assign variant = product.selected_or_first_available_variant
  assign compare_at_price = variant.compare_at_price
  assign price = variant.price
  assign has_variants = product.has_only_default_variant == false
  assign options = product.options_with_values
  assign option_count = options.size
  assign last_option = options.last
-%}

<section class="main-product">
  <div class="container">
    <variant-picker>
      {%- if has_variants -%}
        {%- capture variants_json -%}
          [
            {%- for v in product.variants -%}
              {
                "id": {{ v.id | json }},
                "available": {{ v.available | json }},
                "options": {{ v.options | json }},
                "price": {{ v.price | money | json }},
                "compare_at_price": {% if v.compare_at_price > v.price %}{{ v.compare_at_price | money | json }}{% else %}null{% endif %},
                "featured_image": {% if v.featured_image %}{ "src": {{ v.featured_image | image_url: width: 1600 | json }}, "alt": {{ v.featured_image.alt | default: product.title | json }} }{% else %}null{% endif %}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        {%- endcapture -%}
        <script type="application/json" data-product-variants>{{ variants_json }}</script>
      {%- endif -%}

      <div class="grid md:grid--two main-product__grid">
        <div class="main-product__media">
        {%- if featured_image != blank -%}
          {{
            featured_image
            | image_url: width: 1600
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              sizes: '(min-width: 48em) 50vw, 100vw',
              widths: '400,700,1000,1600',
              class: 'main-product__image',
              alt: featured_image.alt | default: product.title | escape
          }}
        {%- else -%}
          <div class="main-product__placeholder" aria-hidden="true">
            <svg viewBox="0 0 120 120" class="main-product__placeholder-mark">
              <circle cx="60" cy="60" r="38" fill="none" stroke="currentColor" stroke-width="1"/>
              <path d="M60 40v40M40 60h40" stroke="currentColor" stroke-width="1"/>
            </svg>
          </div>
        {%- endif -%}
      </div>

      <div class="main-product__content">
        {%- if product.vendor != blank -%}
          <p class="main-product__vendor">{{ product.vendor | escape }}</p>
        {%- endif -%}

        <h1 class="main-product__title">{{ product.title | escape }}</h1>

        <p class="main-product__price" aria-live="polite">
          {%- if compare_at_price > price -%}
            <span class="main-product__price--sale">{{ price | money }}</span>
            <span class="main-product__compare-price">{{ compare_at_price | money }}</span>
          {%- else -%}
            {{ price | money }}
          {%- endif -%}
        </p>

        {%- if product.description != blank -%}
          <div class="main-product__description">{{ product.description }}</div>
        {%- endif -%}

        {%- if has_variants and option_count > 1 -%}
          <div class="main-product__options">
            {%- for option in options -%}
              {%- assign option_position = forloop.index -%}
              {%- unless forloop.last -%}
                <form method="get" action="{{ product.url }}" class="main-product__option-form">
                  <fieldset class="main-product__option">
                    <legend class="main-product__option-legend">{{ option.name | escape }}</legend>
                    <div class="main-product__option-values">
                      {%- for value in option.values -%}
                        {%- liquid
                          assign candidates = product.variants
                          for other in options
                            assign other_position = forloop.index
                            assign other_key = 'option' | append: other_position
                            if other_position == option_position
                              assign candidates = candidates | where: other_key, value
                            else
                              assign fixed_value = variant.options[forloop.index0]
                              assign candidates = candidates | where: other_key, fixed_value
                            endif
                          endfor
                          assign matched_variant = candidates.first
                          assign current_value = variant.options[option_position | minus: 1]
                          assign is_checked = false
                          if current_value == value
                            assign is_checked = true
                          endif
                          assign is_unavailable = true
                          if matched_variant != blank and matched_variant.available
                            assign is_unavailable = false
                          endif
                        -%}
                        <span class="main-product__option-value">
                          <input
                            type="radio"
                            name="variant"
                            id="Option-{{ section.id }}-{{ option_position }}-{{ forloop.index }}"
                            value="{{ matched_variant.id }}"
                            data-option-position="{{ option_position }}"
                            data-option-value="{{ value | escape }}"
                            class="main-product__option-input visually-hidden"
                            {% if is_checked %}checked{% endif %}
                            {% if is_unavailable %}disabled{% endif %}
                          >
                          <label for="Option-{{ section.id }}-{{ option_position }}-{{ forloop.index }}" class="main-product__option-label">
                            {{ value | escape }}
                            {%- if is_unavailable -%}
                              <span class="visually-hidden"> ({{ 'sections.main_product.sold_out' | t }})</span>
                            {%- endif -%}
                          </label>
                        </span>
                      {%- endfor -%}
                    </div>
                  </fieldset>
                  <button type="submit" class="main-product__option-update">
                    {{ 'sections.main_product.update_selection' | t }}
                  </button>
                </form>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- form 'product', product, class: 'main-product__form' -%}
          {%- if has_variants -%}
            {%- assign last_option_position = option_count -%}
            <fieldset class="main-product__option">
              <legend class="main-product__option-legend">{{ last_option.name | escape }}</legend>
              <div class="main-product__option-values">
                {%- for value in last_option.values -%}
                  {%- liquid
                    assign candidates = product.variants
                    for other in options
                      assign other_position = forloop.index
                      assign other_key = 'option' | append: other_position
                      if other_position == last_option_position
                        assign candidates = candidates | where: other_key, value
                      else
                        assign fixed_value = variant.options[forloop.index0]
                        assign candidates = candidates | where: other_key, fixed_value
                      endif
                    endfor
                    assign matched_variant = candidates.first
                    assign current_value = variant.options[last_option_position | minus: 1]
                    assign is_checked = false
                    if current_value == value
                      assign is_checked = true
                    endif
                    assign is_unavailable = true
                    if matched_variant != blank and matched_variant.available
                      assign is_unavailable = false
                    endif
                  -%}
                  <span class="main-product__option-value">
                    <input
                      type="radio"
                      name="id"
                      id="Option-{{ section.id }}-final-{{ forloop.index }}"
                      value="{{ matched_variant.id }}"
                      data-option-position="{{ last_option_position }}"
                      data-option-value="{{ value | escape }}"
                      class="main-product__option-input visually-hidden"
                      {% if is_checked %}checked{% endif %}
                      {% if is_unavailable %}disabled{% endif %}
                    >
                    <label for="Option-{{ section.id }}-final-{{ forloop.index }}" class="main-product__option-label">
                      {{ value | escape }}
                      {%- if is_unavailable -%}
                        <span class="visually-hidden"> ({{ 'sections.main_product.sold_out' | t }})</span>
                      {%- endif -%}
                    </label>
                  </span>
                {%- endfor -%}
              </div>
            </fieldset>
          {%- else -%}
            <input type="hidden" name="id" value="{{ variant.id }}">
          {%- endif -%}
          <button
            type="submit"
            name="add"
            class="main-product__button"
            data-add-to-cart-label="{{ 'sections.main_product.add_to_cart' | t }}"
            data-sold-out-label="{{ 'sections.main_product.sold_out' | t }}"
            {% if variant.available == false %}disabled{% endif %}
          >
            {%- if variant.available -%}
              {{ 'sections.main_product.add_to_cart' | t }}
            {%- else -%}
              {{ 'sections.main_product.sold_out' | t }}
            {%- endif -%}
          </button>
        {%- endform -%}
      </div>
      </div>
    </variant-picker>
  </div>
</section>

{% schema %}
{
  "name": "Product information"
}
{% endschema %}
