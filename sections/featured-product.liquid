{% comment %}
  Featured Product — editorial spotlight on one merchant-selected
  product. Same architecture as sections/image-with-text.liquid (two-
  column media + content grid, desktop reorder via CSS `order`, mobile
  always stacks media-first) but content is product-data-driven rather
  than block-based — there's no "Blocks" concept here because title,
  vendor, price, and description all come directly from the picked
  product, not merchant free text. The only merchant-authored copy is
  the optional secondary button (a plain settings pair, not a block,
  since it's singular and unstyled beyond "secondary").

  No product selected → this section renders nothing on the live
  storefront (Theme Editor gets a prompt instead), same as
  sections/featured-collection.liquid: unlike Hero or Image with Text,
  which can stand on merchant-authored blocks alone, a product spotlight
  has no meaningful content without a product.

  Media ratio is a first-class merchant setting (3:4 / 4:5 / 1:1)
  applied at every breakpoint. This deliberately does NOT reuse Image
  with Text's desktop "stretch to row height" trick — that behavior
  would fight a merchant-chosen fixed ratio.

  No variant picker or add-to-cart form: this is a spotlight linking to
  the full product page, not a purchase widget, and a variant picker
  would need either JS or a full <form> flow that's out of scope here.
{% endcomment %}

{{ 'featured-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign product = section.settings.product
  assign media_position = section.settings.media_position
  assign media_ratio = section.settings.media_ratio
  assign vertical_alignment = section.settings.vertical_alignment
  assign content_width = section.settings.content_width
  assign background = section.settings.background
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign show_vendor = section.settings.show_vendor
  assign secondary_button_label = section.settings.secondary_button_label
  assign secondary_button_link = section.settings.secondary_button_link
-%}

{%- if product != blank or request.design_mode -%}
  <section
    class="featured-product"
    data-media-position="{{ media_position }}"
    data-media-ratio="{{ media_ratio }}"
    data-vertical-alignment="{{ vertical_alignment }}"
    data-content-width="{{ content_width }}"
    data-background="{{ background }}"
    data-padding-top="{{ padding_top }}"
    data-padding-bottom="{{ padding_bottom }}"
  >
    <div class="container">
      {%- if product == blank -%}
        {%- comment -%}
          Only reachable in the Theme Editor: the outer blank-product
          check that wraps this whole section (see the top of this
          file) means the section is skipped entirely on the live
          storefront when no product is set.
        {%- endcomment -%}
        <p class="featured-product__empty">{{ 'sections.featured_product.editor_empty' | t }}</p>
      {%- else -%}
        <div class="grid md:grid--two featured-product__grid">
          <div class="featured-product__media">
            {%- if product.featured_image != blank -%}
              {{
                product.featured_image
                | image_url: width: 1600
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 48em) 50vw, 100vw',
                  widths: '400,700,1000,1600',
                  class: 'featured-product__image',
                  alt: product.featured_image.alt | default: product.title | escape
              }}
            {%- else -%}
              <div class="featured-product__placeholder" aria-hidden="true">
                <svg viewBox="0 0 120 120" class="featured-product__placeholder-mark">
                  <circle cx="60" cy="60" r="38" fill="none" stroke="currentColor" stroke-width="1"/>
                  <path d="M60 40v40M40 60h40" stroke="currentColor" stroke-width="1"/>
                </svg>
              </div>
            {%- endif -%}

            {%- if product.available == false -%}
              <span class="featured-product__badge featured-product__badge--sold-out">{{ 'sections.featured_product.sold_out_badge' | t }}</span>
            {%- elsif product.compare_at_price > product.price -%}
              <span class="featured-product__badge featured-product__badge--sale">{{ 'sections.featured_product.sale_badge' | t }}</span>
            {%- endif -%}
          </div>

          <div class="featured-product__content-column">
            <div class="featured-product__content">
              {%- if show_vendor and product.vendor != blank -%}
                <p class="featured-product__vendor">{{ product.vendor | escape }}</p>
              {%- endif -%}

              <h2 class="featured-product__title">{{ product.title | escape }}</h2>

              <p class="featured-product__price">
                {%- if product.compare_at_price > product.price -%}
                  <span class="featured-product__price--sale">{{ product.price | money }}</span>
                  <span class="featured-product__compare-price">{{ product.compare_at_price | money }}</span>
                {%- else -%}
                  {{ product.price | money }}
                {%- endif -%}
              </p>

              <p class="featured-product__availability{% if product.available == false %} featured-product__availability--sold-out{% endif %}">
                {%- if product.available -%}
                  {{ 'sections.featured_product.in_stock' | t }}
                {%- else -%}
                  {{ 'sections.featured_product.sold_out_badge' | t }}
                {%- endif -%}
              </p>

              {%- if product.description != blank -%}
                <div class="featured-product__description">
                  {{ product.description | strip_html | truncatewords: 40 }}
                </div>
              {%- endif -%}

              <div class="featured-product__actions">
                <a href="{{ product.url }}" class="featured-product__button featured-product__button--primary">
                  {{ 'sections.featured_product.view_product' | t }}
                </a>

                {%- if secondary_button_label != blank -%}
                  <a
                    {% if secondary_button_link != blank %}href="{{ secondary_button_link }}"{% else %}role="link" aria-disabled="true"{% endif %}
                    class="featured-product__button featured-product__button--secondary"
                  >
                    {{ secondary_button_label | escape }}
                  </a>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Featured product",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "info": "Optional, e.g. a link to a size guide or care instructions."
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Desktop media position",
      "info": "On mobile, the media always appears above the content.",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "media_ratio",
      "label": "Media ratio",
      "options": [
        { "value": "3:4", "label": "3:4" },
        { "value": "4:5", "label": "4:5" },
        { "value": "1:1", "label": "1:1" }
      ],
      "default": "4:5"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical content alignment",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "medium", "label": "Medium" },
        { "value": "wide", "label": "Wide" }
      ],
      "default": "medium"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "options": [
        { "value": "none", "label": "Default" },
        { "value": "muted", "label": "Muted" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Top spacing",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ],
  "presets": [
    {
      "name": "Featured product"
    }
  ]
}
{% endschema %}
