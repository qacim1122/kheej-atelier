{% comment %}
  Main 404 — self-contained, no settings (nothing merchant-configurable
  is needed for a not-found page).
{% endcomment %}

{{ 'main-404.css' | asset_url | stylesheet_tag }}

<section class="main-404">
  <div class="container">
    <p class="main-404__eyebrow">404</p>
    <h1 class="main-404__title">{{ 'sections.main_404.title' | t }}</h1>
    <p class="main-404__message">{{ 'sections.main_404.message' | t }}</p>
    <a href="{{ routes.root_url }}" class="main-404__link">{{ 'sections.main_404.back_to_home' | t }}</a>
  </div>
</section>

{% schema %}
{
  "name": "404 page"
}
{% endschema %}
