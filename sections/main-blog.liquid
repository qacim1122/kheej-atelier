{% comment %}
  Main Blog — article list with pagination. Reuses snippets/
  pagination.liquid (shared with Collection/Search). Article card
  markup is self-contained here (not extracted to a snippet — only this
  template needs it).
{% endcomment %}

{{ 'main-blog.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign articles_per_page = section.settings.articles_per_page
-%}

<section class="main-blog">
  <div class="container">
    <h1 class="main-blog__title">{{ blog.title | escape }}</h1>

    {%- if blog.articles.size == 0 -%}
      <p class="main-blog__empty">{{ 'sections.main_blog.empty' | t }}</p>
    {%- else -%}
      {%- paginate blog.articles by articles_per_page -%}
        <ul class="grid md:grid--two main-blog__grid" role="list">
          {%- for article in blog.articles -%}
            <li>
              <article class="main-blog__card">
                <a href="{{ article.url }}" class="main-blog__card-media">
                  {%- if article.image != blank -%}
                    {{
                      article.image
                      | image_url: width: 800
                      | image_tag:
                        loading: 'lazy',
                        sizes: '(min-width: 48em) 50vw, 100vw',
                        widths: '400,600,800',
                        class: 'main-blog__card-image',
                        alt: article.image.alt | default: article.title | escape
                    }}
                  {%- else -%}
                    <span class="main-blog__card-placeholder" aria-hidden="true"></span>
                  {%- endif -%}
                </a>
                <div class="main-blog__card-content">
                  <p class="main-blog__card-meta">
                    <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %d, %Y' }}</time>
                    {%- if article.author != blank %} &middot; {{ article.author }}{% endif -%}
                  </p>
                  <h2 class="main-blog__card-title">
                    <a href="{{ article.url }}" class="main-blog__card-link">{{ article.title | escape }}</a>
                  </h2>
                  {%- if article.excerpt != blank -%}
                    <p class="main-blog__card-excerpt">{{ article.excerpt | strip_html | truncatewords: 30 }}</p>
                  {%- endif -%}
                </div>
              </article>
            </li>
          {%- endfor -%}
        </ul>

        {% render 'pagination', paginate: paginate %}
      {%- endpaginate -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "Articles per page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 12
    }
  ]
}
{% endschema %}
