{% comment %}
  Hero — full-bleed editorial entry point, rendered as the first section
  on the homepage (see templates/index.json).

  Self-contained by design: no shared components.css or button/section-
  heading/responsive-media snippets exist in this repository, so all
  markup and styling for eyebrow/heading/subheading/button typography
  lives directly in hero.css. If a shared components layer is added
  later, the class names below (.hero__eyebrow, .hero__title,
  .hero__subheading, .hero__button) are deliberately plain and easy to
  re-point at shared component classes without a markup rewrite.

  Content (eyebrow / heading / rich text / buttons) is block-based so
  merchants can add, remove, reorder, or omit any piece freely. Image
  and layout settings stay at the section level — a hero only makes
  sense with one image and one set of layout rules, but its copy is
  genuinely variable per campaign.

  Enumerated merchant settings (height, alignment, vertical position,
  content width, spacing) are applied via data-attributes + a small set
  of CSS custom properties they set — no inline style attribute. Overlay
  opacity and overlay color are the two settings that need a computed
  value rather than a fixed enum-to-value CSS rule, so they're set via
  the same section-scoped {% style %} block (a real stylesheet, not an
  inline style attribute).
{% endcomment %}

{{ 'hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign image = section.settings.image
  assign caption = section.settings.caption
  assign show_scroll_indicator = section.settings.show_scroll_indicator
  assign heading_text = blank
  for block in section.blocks
    if block.type == 'heading' and block.settings.text != blank
      assign heading_text = block.settings.text
      break
    endif
  endfor
  assign overlay_opacity = section.settings.overlay_opacity
  assign overlay_color = section.settings.overlay_color
  assign height = section.settings.height
  assign desktop_alignment = section.settings.desktop_alignment
  assign mobile_alignment = section.settings.mobile_alignment
  assign vertical_position = section.settings.vertical_position
  assign content_width = section.settings.content_width
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom

  case overlay_color
    when 'background'
      assign overlay_color_var = '--color-background'
    when 'accent'
      assign overlay_color_var = '--color-accent'
    else
      assign overlay_color_var = '--color-text-primary'
  endcase
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .hero {
    --hero-overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }};
    --hero-overlay-color: var({{ overlay_color_var }});
  }
{%- endstyle -%}

<section
  class="hero{% if image == blank %} hero--no-image{% endif %}"
  data-height="{{ height }}"
  data-desktop-alignment="{{ desktop_alignment }}"
  data-mobile-alignment="{{ mobile_alignment }}"
  data-vertical-position="{{ vertical_position }}"
  data-content-width="{{ content_width }}"
  data-padding-top="{{ padding_top }}"
  data-padding-bottom="{{ padding_bottom }}"
>
  <div class="hero__media">
    {%- if image != blank -%}
      {{
        image
        | image_url: width: 3200
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '750,1100,1500,2200,3200',
          class: 'hero__image',
          alt: image.alt | default: heading_text | escape
      }}

      {%- if overlay_opacity > 0 -%}
        <div class="hero__overlay" aria-hidden="true"></div>
      {%- endif -%}
    {%- else -%}
      {%- comment -%}
        Editorial placeholder — a soft token-based gradient with a thin
        centered mark, not Shopify's default gray "broken image" glyph.
        Renders everywhere (storefront included), not just in the
        Theme Editor, so a hero with copy but no image yet still looks
        intentional rather than empty.
      {%- endcomment -%}
      <div class="hero__placeholder" aria-hidden="true">
        <svg viewBox="0 0 120 120" class="hero__placeholder-mark">
          <circle cx="60" cy="60" r="38" fill="none" stroke="currentColor" stroke-width="1"/>
          <path d="M60 40v40M40 60h40" stroke="currentColor" stroke-width="1"/>
        </svg>
      </div>
    {%- endif -%}
  </div>

  <div class="hero__container container">
    <div class="hero__content">
      {%- assign buttons_open = false -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'eyebrow' -%}
            {%- if buttons_open -%}</div>{%- assign buttons_open = false -%}{%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="hero__eyebrow" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</p>
            {%- endif -%}

          {%- when 'heading' -%}
            {%- if buttons_open -%}</div>{%- assign buttons_open = false -%}{%- endif -%}
            {%- if block.settings.text != blank -%}
              <h1 class="hero__title" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</h1>
            {%- endif -%}

          {%- when 'text' -%}
            {%- if buttons_open -%}</div>{%- assign buttons_open = false -%}{%- endif -%}
            {%- if block.settings.content != blank -%}
              <div class="hero__subheading" {{ block.shopify_attributes }}>{{ block.settings.content }}</div>
            {%- endif -%}

          {%- when 'button' -%}
            {%- if block.settings.label != blank -%}
              {%- unless buttons_open -%}
                <div class="hero__actions">
                {%- assign buttons_open = true -%}
              {%- endunless -%}
              <a
                {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% else %}role="link" aria-disabled="true"{% endif %}
                class="hero__button hero__button--{{ block.settings.style }}"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.label | escape }}
              </a>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
      {%- if buttons_open -%}</div>{%- endif -%}
    </div>

    {%- if caption != blank -%}
      <p class="hero__caption">{{ caption | escape }}</p>
    {%- endif -%}
  </div>

  {%- if show_scroll_indicator -%}
    <a href="#MainContent" class="hero__scroll-indicator" aria-label="{{ 'sections.hero.scroll_to_content' | t }}">
      {%- render 'icon', icon: 'chevron-down' -%}
    </a>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "If left blank, an editorial placeholder is shown instead of an empty background."
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "info": "Optional small print, e.g. a credit line or a shipping note.",
      "default": "Photographed in Milan"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "info": "Darkens the image to keep text legible. Set to 0 to disable. Has no effect when no image is set.",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "select",
      "id": "overlay_color",
      "label": "Overlay color",
      "options": [
        { "value": "background", "label": "Background" },
        { "value": "text", "label": "Text" },
        { "value": "accent", "label": "Accent" }
      ],
      "default": "text"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Hero height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full_screen", "label": "Full screen" }
      ],
      "default": "large"
    },
    {
      "type": "select",
      "id": "vertical_position",
      "label": "Vertical content position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "desktop_alignment",
      "label": "Desktop content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "mobile_alignment",
      "label": "Mobile alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "Content width",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "medium", "label": "Medium" },
        { "value": "wide", "label": "Wide" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Top spacing",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "none"
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "New Season"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Quiet luxury, considered detail"
        }
      ]
    },
    {
      "type": "text",
      "name": "Rich text",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>An edit of pieces built to last beyond the season, in fabrics chosen for how they wear, not just how they photograph.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Shop the edit"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "primary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "button", "settings": { "label": "Shop the edit", "style": "primary" } },
        { "type": "button", "settings": { "label": "Our story", "style": "secondary" } }
      ]
    }
  ]
}
{% endschema %}
