{% comment %}
  Main Password — real Shopify storefront_password form. Works with
  zero JS (standard POST, native validation, posted_successfully?/
  errors from Shopify).
{% endcomment %}

{{ 'main-password.css' | asset_url | stylesheet_tag }}

<section class="main-password">
  <div class="container">
    {%- if shop.logo != blank -%}
      {{ shop.logo | image_url: width: 300 | image_tag: width: 150, class: 'main-password__logo', alt: shop.name }}
    {%- else -%}
      <p class="main-password__shop-name">{{ shop.name | escape }}</p>
    {%- endif -%}

    <h1 class="main-password__title">{{ 'sections.main_password.title' | t }}</h1>

    {%- form 'storefront_password', class: 'main-password__form' -%}
      <label for="Password" class="visually-hidden">{{ 'sections.main_password.password_label' | t }}</label>
      <input
        type="password"
        name="password"
        id="Password"
        class="main-password__input"
        placeholder="{{ 'sections.main_password.password_placeholder' | t }}"
        {% if form.errors %}aria-invalid="true" aria-describedby="PasswordError"{% endif %}
      >
      <button type="submit" class="main-password__submit">{{ 'sections.main_password.submit' | t }}</button>

      {%- if form.errors -%}
        <p id="PasswordError" class="main-password__error" role="alert">
          {{ 'sections.main_password.error' | t }}
        </p>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Password page"
}
{% endschema %}
