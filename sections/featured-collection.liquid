{% comment %}
  Featured Collection — merchandising rail showcasing products from one
  merchant-selected collection. Named/filed per CODING_STANDARDS.md's own
  naming example ("featured-collection.liquid") and ROADMAP.md Phase 5
  ("Featured collection section") — singular: one collection's products,
  not a grid of collection entry points (that's a different pattern).

  Same architecture as sections/hero.liquid:
  - Self-contained CSS (no shared components.css exists in this repo).
  - Narrative copy (eyebrow/heading/rich text/buttons) is block-based for
    merchant flexibility; the data-bound and structural settings
    (collection, product count, columns, spacing) stay at the section
    level, same split as Hero's "image and layout at section level".
  - Enumerated settings applied via data-attributes + a small set of CSS
    custom properties, no inline style attribute.
  - Product grid reuses assets/utilities.css's .grid / .grid--two /
    .md:grid--two / .md:grid--three directly (composed here via Liquid)
    rather than adding new grid CSS — see featured-collection.css header
    comment for why desktop columns are capped at 2/3, not 2/3/4.

  .product-card is deliberately plain BEM (not
  .featured-collection__product-card): CODING_STANDARDS.md's own naming
  example lists product-card.liquid as an anticipated component, so this
  is named to be trivially portable into a shared component/snippet
  later, same reasoning as Hero's .hero__button classes.
{% endcomment %}

{{ 'featured-collection.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection = section.settings.collection
  assign products_to_show = section.settings.products_to_show
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile
  assign heading_alignment = section.settings.heading_alignment
  assign background = section.settings.background
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom

  assign grid_classes = 'grid featured-collection__grid'
  if columns_mobile == '2'
    assign grid_classes = grid_classes | append: ' grid--two'
  endif
  if columns_desktop == '2'
    assign grid_classes = grid_classes | append: ' md:grid--two'
  else
    assign grid_classes = grid_classes | append: ' md:grid--three'
  endif
-%}

{%- if collection != blank or request.design_mode -%}
  <section
    class="featured-collection"
    data-background="{{ background }}"
    data-padding-top="{{ padding_top }}"
    data-padding-bottom="{{ padding_bottom }}"
  >
    <div class="container">
      {%- if section.blocks.size > 0 -%}
        <div class="featured-collection__header {{ heading_alignment | prepend: 'text-' }}">
          {%- assign buttons_open = false -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'eyebrow' -%}
                {%- if buttons_open -%}</div>{%- assign buttons_open = false -%}{%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="featured-collection__eyebrow" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</p>
                {%- endif -%}

              {%- when 'heading' -%}
                {%- if buttons_open -%}</div>{%- assign buttons_open = false -%}{%- endif -%}
                {%- if block.settings.text != blank -%}
                  <h2 class="featured-collection__title" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</h2>
                {%- endif -%}

              {%- when 'text' -%}
                {%- if buttons_open -%}</div>{%- assign buttons_open = false -%}{%- endif -%}
                {%- if block.settings.content != blank -%}
                  <div class="featured-collection__subheading" {{ block.shopify_attributes }}>{{ block.settings.content }}</div>
                {%- endif -%}

              {%- when 'button' -%}
                {%- if block.settings.label != blank -%}
                  {%- unless buttons_open -%}
                    <div class="featured-collection__actions">
                    {%- assign buttons_open = true -%}
                  {%- endunless -%}
                  {%- liquid
                    assign button_link = block.settings.link
                    if button_link == blank and collection != blank
                      assign button_link = collection.url
                    endif
                  -%}
                  <a
                    {% if button_link != blank %}href="{{ button_link }}"{% else %}role="link" aria-disabled="true"{% endif %}
                    class="featured-collection__button featured-collection__button--{{ block.settings.style }}"
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.label | escape }}
                  </a>
                {%- endif -%}
            {%- endcase -%}
          {%- endfor -%}
          {%- if buttons_open -%}</div>{%- endif -%}
        </div>
      {%- endif -%}

      {%- if collection == blank -%}
        {%- comment -%}
          Only reachable in the Theme Editor: the outer {% if collection
          != blank or request.design_mode %} above means the whole
          section is skipped on the live storefront when no collection
          is set.
        {%- endcomment -%}
        <p class="featured-collection__empty">{{ 'sections.featured_collection.editor_empty' | t }}</p>
      {%- elsif collection.products.size == 0 -%}
        <p class="featured-collection__empty">{{ 'sections.featured_collection.empty' | t }}</p>
      {%- else -%}
        <ul class="{{ grid_classes }}" role="list">
          {%- for product in collection.products limit: products_to_show -%}
            <li>
              <div class="product-card">
                <div class="product-card__media">
                  {%- if product.featured_image != blank -%}
                    {{
                      product.featured_image
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        sizes: '(min-width: 64em) 30vw, (min-width: 48em) 40vw, 90vw',
                        widths: '400,600,900,1200',
                        class: 'product-card__image'
                    }}
                  {%- else -%}
                    <div class="product-card__placeholder" aria-hidden="true">
                      <svg viewBox="0 0 120 120" class="product-card__placeholder-mark">
                        <circle cx="60" cy="60" r="38" fill="none" stroke="currentColor" stroke-width="1"/>
                        <path d="M60 40v40M40 60h40" stroke="currentColor" stroke-width="1"/>
                      </svg>
                    </div>
                  {%- endif -%}

                  {%- if product.available == false -%}
                    <span class="product-card__badge product-card__badge--sold-out">{{ 'sections.featured_collection.sold_out_badge' | t }}</span>
                  {%- elsif product.compare_at_price > product.price -%}
                    <span class="product-card__badge product-card__badge--sale">{{ 'sections.featured_collection.sale_badge' | t }}</span>
                  {%- endif -%}
                </div>

                <div class="product-card__content">
                  <h3 class="product-card__title">
                    <a href="{{ product.url }}" class="product-card__link">
                      {{ product.title | escape }}
                      <span class="visually-hidden"> — {{ 'sections.featured_collection.view_product' | t }}</span>
                    </a>
                  </h3>

                  <p class="product-card__price">
                    {%- if product.compare_at_price > product.price -%}
                      <span class="product-card__price--sale">{{ product.price | money }}</span>
                      <span class="product-card__compare-price">{{ product.compare_at_price | money }}</span>
                    {%- else -%}
                      {{ product.price | money }}
                    {%- endif -%}
                  </p>
                </div>
              </div>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Mobile columns",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "options": [
        { "value": "none", "label": "Default" },
        { "value": "muted", "label": "Muted" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Top spacing",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Just In"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "New arrivals"
        }
      ]
    },
    {
      "type": "text",
      "name": "Rich text",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 2,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "View all"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Defaults to the collection page if left blank."
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" }
          ],
          "default": "secondary"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured collection",
      "blocks": [
        { "type": "heading" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
